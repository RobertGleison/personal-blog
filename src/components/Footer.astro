---
import { type Locale, defaultLocale } from '../i18n/config';
import { translate, getLocalePrefix } from '../i18n/utils';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const localePrefix = getLocalePrefix(locale);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="footer-name">Robert Gleison</span>
        <p class="footer-tagline">Data Engineering & Backend Development</p>
      </div>
      <div class="footer-links">
        <a href={`${localePrefix}/`}>{translate(locale, 'nav.home')}</a>
        <a href={`${localePrefix}/posts/`}>{translate(locale, 'nav.posts')}</a>
        <a href={`${localePrefix}/rss.xml`}>RSS</a>
      </div>
      <div class="footer-social">
        <a href="https://github.com/RobertGleison" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/robertgleison/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
            <rect x="2" y="9" width="4" height="12"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; {year} Robert Gleison. {translate(locale, 'footer.copyright')}</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    border-top: 1px solid var(--border-color);
    background: var(--bg-secondary);
  }

  .footer-container {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 3rem 2rem 2rem;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
  }

  .footer-brand {
    flex: 1;
  }

  .footer-name {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary);
    display: block;
    margin-bottom: 0.25rem;
  }

  .footer-tagline {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .footer-links a {
    color: var(--text-tertiary);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--accent-color);
  }

  .footer-social {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .footer-social a {
    color: var(--text-muted);
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }

  .footer-social a:hover {
    color: var(--accent-color);
  }

  .footer-bottom {
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .footer-top {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1.5rem;
    }

    .footer-container {
      padding: 2rem 1.5rem 1.5rem;
    }
  }
</style>
