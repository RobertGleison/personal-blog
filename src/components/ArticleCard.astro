---
import { type Locale, defaultLocale } from '../i18n/config';
import { formatDate, translate, translateTag } from '../i18n/utils';

interface Props {
    url: string;
    title: string;
    description?: string;
    pubDate: Date;
    author?: string;
    image?: {
      url: string;
      alt: string;
    };
    tags?: string[];
    locale?: Locale;
}

const { url, title, description, pubDate, author, image, tags, locale = defaultLocale } = Astro.props;
---

<article class="article-card">
    <a href={url} class="article-link">
        {image && (
          <div class="article-image">
            <img src={image.url} alt={image.alt} loading="lazy" />
          </div>
        )}
        <div class="article-content">
            <div class="article-content-inner">
              <div class="article-meta-top">
                {tags && tags.length > 0 && (
                    <span class="article-category">{translateTag(tags[0], locale)}</span>
                )}
                <time datetime={pubDate.toISOString()}>{formatDate(pubDate, locale)}</time>
              </div>
              <h2 class="article-title">{title}</h2>
              <p class="article-description">{description}</p>
            </div>
            <div class="article-footer">
                {tags && tags.length > 1 && (
                    <div class="article-tags">
                        {tags.slice(1).map((tag) => (
                            <span class="tag-badge">{tag}</span>
                        ))}
                    </div>
                )}
                <span class="read-more">{translate(locale, 'article.read')} &rarr;</span>
            </div>
        </div>
    </a>
</article>

<style>
  .article-card {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
    position: relative;
  }

  .article-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--accent-color);
    transform: scaleY(0);
    transition: transform 0.3s ease;
    border-radius: 8px 0 0 8px;
    z-index: 1;
  }

  .article-card:hover {
    border-color: var(--accent-color);
    box-shadow: 0 4px 20px var(--shadow-sm);
  }

  .article-card:hover::before {
    transform: scaleY(1);
  }

  .article-link {
    text-decoration: none;
    color: inherit;
    display: grid;
    grid-template-columns: 280px 1fr;
    grid-template-rows: 200px;
    gap: 0;
  }

  .article-image {
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: var(--bg-tertiary);
  }

  .article-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .article-card:hover .article-image img {
    transform: scale(1.03);
  }

  .article-content {
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
  }

  .article-meta-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 500;
  }

  .article-category {
    color: var(--accent-color);
    font-weight: 600;
  }

  .article-title {
    font-family: var(--font-display, 'Source Sans 3', sans-serif);
    font-size: 1.35rem;
    font-weight: 500;
    margin: 0 0 0.5rem 0;
    color: var(--text-primary);
    line-height: 1.35;
    transition: color 0.2s ease;
  }

  .article-card:hover .article-title {
    color: var(--accent-color);
  }

  .article-description {
    color: var(--text-tertiary);
    margin-bottom: 0;
    line-height: 1.6;
    font-size: 0.95rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag-badge {
    background: var(--bg-tertiary);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-weight: 500;
  }

  .read-more {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-color);
    white-space: nowrap;
    transition: transform 0.2s;
    display: inline-block;
    margin-left: auto;
  }

  .article-card:hover .read-more {
    transform: translateX(3px);
  }

  @media (max-width: 768px) {
    .article-link {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .article-image {
      height: 180px;
    }

    .article-content {
      padding: 1.25rem;
    }

    .article-title {
      font-size: 1.2rem;
    }
  }
</style>
