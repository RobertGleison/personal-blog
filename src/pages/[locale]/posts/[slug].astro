---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { translate, formatDate } from '../../../i18n/utils';
import { locales, type Locale } from '../../../i18n/config';

export async function getStaticPaths() {
  const paths = [];
  for (const locale of locales) {
    const posts = await getCollection('posts', ({ id }) => id.startsWith(`${locale}/`));
    for (const post of posts) {
      paths.push({
        params: { locale, slug: post.slug.replace(`${locale}/`, '') },
        props: { post, locale },
      });
    }
  }
  return paths;
}

const { post, locale } = Astro.props as { post: any; locale: Locale };
const { Content } = await post.render();

const allPosts = await getCollection('posts', ({ id }) => id.startsWith(`${locale}/`));
const sortedPosts = allPosts.sort((a, b) =>
  b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const currentIndex = sortedPosts.findIndex((p) => p.slug === post.slug);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

const authorLabel = locale === 'pt' ? 'por' : 'by';

// Estimate reading time
const wordCount = post.body?.split(/\s+/).length || 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
const readingLabel = locale === 'pt' ? 'min de leitura' : 'min read';
---

<BaseLayout title={post.data.title} description={post.data.description} locale={locale}>
  <div class="reading-progress" id="reading-progress"></div>

  <article class="post-container">
    <a href={`/${locale}/posts/`} class="back-button">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      {translate(locale, 'article.back')}
    </a>

    <header class="post-header">
      {post.data.tags && (
        <div class="post-tags">
          {post.data.tags.map((tag: string) => (
            <span class="tag-badge">{tag}</span>
          ))}
        </div>
      )}
      <h1>{post.data.title}</h1>
      <div class="post-meta">
        <div class="post-meta-left">
          <time datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate, locale)}
          </time>
          {post.data.author && <span class="meta-sep">&middot;</span>}
          {post.data.author && <span class="author">{authorLabel} {post.data.author}</span>}
          <span class="meta-sep">&middot;</span>
          <span class="reading-time">{readingTime} {readingLabel}</span>
        </div>
      </div>
    </header>

    {post.data.image && (
      <div class="post-image">
        <img src={post.data.image.url} alt={post.data.image.alt} />
      </div>
    )}

    <div class="post-content">
      <Content />
    </div>

    <button class="scroll-to-top" id="scroll-to-top" aria-label={translate(locale, 'article.scrollToTop')}>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 19V5M5 12l7-7 7 7"/>
      </svg>
    </button>

    <nav class="post-navigation">
      {prevPost && (
        <a href={`/${locale}/posts/${prevPost.slug.replace(`${locale}/`, '')}/`} class="nav-link prev">
          <span class="nav-direction">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 18l-6-6 6-6"/>
            </svg>
            {translate(locale, 'article.previous')}
          </span>
          <span class="nav-title">{prevPost.data.title}</span>
        </a>
      )}
      {nextPost && (
        <a href={`/${locale}/posts/${nextPost.slug.replace(`${locale}/`, '')}/`} class="nav-link next">
          <span class="nav-direction">
            {translate(locale, 'article.next')}
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </span>
          <span class="nav-title">{nextPost.data.title}</span>
        </a>
      )}
    </nav>
  </article>
</BaseLayout>

<script>
  function initReadingProgress() {
    const progressBar = document.getElementById('reading-progress');
    const scrollBtn = document.getElementById('scroll-to-top');
    if (!progressBar) return;

    function updateProgress() {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      progressBar.style.width = `${Math.min(progress, 100)}%`;

      if (scrollBtn) {
        if (scrollTop > 400) {
          scrollBtn.classList.add('visible');
        } else {
          scrollBtn.classList.remove('visible');
        }
      }
    }

    if (scrollBtn) {
      const newBtn = scrollBtn.cloneNode(true) as HTMLElement;
      scrollBtn.parentNode?.replaceChild(newBtn, scrollBtn);
      newBtn.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  }

  initReadingProgress();
  document.addEventListener('astro:page-load', initReadingProgress);
</script>

<style>
  .reading-progress {
    position: fixed;
    top: var(--nav-height, 64px);
    left: 0;
    height: 2px;
    width: 0%;
    background: linear-gradient(90deg, var(--accent-color), var(--accent-light, var(--accent-color)));
    z-index: 99;
    transition: width 0.1s linear;
  }

  .post-container {
    max-width: var(--container-narrow, 780px);
    margin: 0 auto;
    padding: 2.5rem 2rem 4rem;
  }

  .back-button {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 2.5rem;
    transition: color 0.2s;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .back-button:hover {
    color: var(--accent-color);
  }

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border-color);
  }

  .post-header h1 {
    font-family: var(--font-display, 'Source Sans 3', sans-serif);
    font-size: 2.75rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 1.25rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .post-meta-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .meta-sep {
    color: var(--border-color);
  }

  .reading-time {
    color: var(--text-muted);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .tag-badge {
    background: var(--bg-tertiary);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.75rem;
    color: var(--accent-color);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
  }

  .post-image {
    margin-bottom: 2.5rem;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border-color);
  }

  .post-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Post Content Typography */
  .post-content {
    color: var(--text-secondary);
    line-height: 1.85;
    font-size: 1.05rem;
  }

  .post-content :global(h2) {
    font-family: var(--font-display, 'Source Sans 3', sans-serif);
    font-size: 1.75rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-top: 3rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .post-content :global(h3) {
    font-family: var(--font-display, 'Source Sans 3', sans-serif);
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--text-primary);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.35;
  }

  .post-content :global(h4) {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.4rem;
  }

  .post-content :global(a) {
    color: var(--accent-color);
    text-decoration: underline;
    text-decoration-color: rgba(196, 93, 62, 0.3);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s;
  }

  .post-content :global(a:hover) {
    text-decoration-color: var(--accent-color);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 1.4rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.4rem;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--accent-color);
    padding: 0.75rem 1.25rem;
    margin: 1.75rem 0;
    color: var(--text-tertiary);
    font-style: italic;
    background: var(--bg-secondary);
    border-radius: 0 6px 6px 0;
  }

  .post-content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.75rem 0;
    border: 1px solid var(--border-color);
  }

  .post-content :global(hr) {
    border: none;
    height: 1px;
    background: var(--border-color);
    margin: 2.5rem 0;
  }

  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.75rem 0;
    font-size: 0.95rem;
  }

  .post-content :global(th),
  .post-content :global(td) {
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--border-color);
    text-align: left;
  }

  .post-content :global(th) {
    background: var(--bg-secondary);
    font-weight: 600;
    color: var(--text-primary);
  }

  .post-content :global(strong) {
    font-weight: 600;
    color: var(--text-primary);
  }

  /* Scroll to top */
  .scroll-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--accent-color);
    color: white;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px var(--shadow-md);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s, background 0.2s;
    z-index: 50;
  }

  .scroll-to-top.visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .scroll-to-top:hover {
    background: var(--accent-light, var(--accent-color));
    transform: translateY(-2px);
  }

  /* Post Navigation */
  .post-navigation {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }

  .nav-link {
    padding: 1.25rem;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nav-link:hover {
    border-color: var(--accent-color);
    box-shadow: 0 2px 12px var(--shadow-sm);
  }

  .nav-link.next {
    text-align: right;
    align-items: flex-end;
  }

  .nav-direction {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .nav-title {
    font-family: var(--font-display, 'Playfair Display', serif);
    color: var(--text-primary);
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1.4;
  }

  .nav-link:hover .nav-title {
    color: var(--accent-color);
  }

  @media (max-width: 768px) {
    .post-container {
      padding: 1.5rem 1.5rem 3rem;
    }

    .post-header h1 {
      font-size: 2rem;
    }

    .post-content {
      font-size: 1rem;
    }

    .post-navigation {
      grid-template-columns: 1fr;
    }

    .nav-link.next {
      text-align: left;
      align-items: flex-start;
    }
  }
</style>
