---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { translate } from '../../i18n/utils';
import { locales, type Locale } from '../../i18n/config';
import logo from '../../assets/alternative_logo.png';

export function getStaticPaths() {
  return locales.map((l) => ({ params: { locale: l } }));
}

const locale = Astro.params.locale as Locale;

const allPosts = await getCollection('posts', ({ id }) => id.startsWith(`${locale}/`));
const sortedPosts = allPosts.sort((a, b) =>
  b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const recentPosts = sortedPosts.slice(0, 3);
---

<BaseLayout title="Home | Robert Gleison" description={translate(locale, 'home.welcome')} locale={locale}>

    <div class="hero-section">
      <div class="hero-container">
          <div class="hero-content">
              <div class="hero-intro">
                <img src={logo.src} alt="Robert Gleison" class="hero-avatar" />
                <div class="hero-meta">
                  <span class="hero-greeting">{translate(locale, 'home.welcome')}</span>
                  <h1 class="hero-title">Robert Gleison</h1>
                  <p class="hero-role">Data Engineer & Backend Developer</p>
                </div>
              </div>
              <div class="hero-bio">
                <p>{translate(locale, 'home.intro')}</p>
                <p>{translate(locale, 'home.about')}</p>
              </div>
          </div>
          <div class="hero-decoration" aria-hidden="true">
            <svg class="git-graph" width="24" height="196" viewBox="0 0 24 196" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- main branch line -->
              <line x1="12" y1="20" x2="12" y2="176" class="line-main" stroke-width="2"/>
              <!-- commits -->
              <circle cx="12" cy="20" r="5" class="dot-main"/>
              <circle cx="12" cy="72" r="5" class="dot-main"/>
              <circle cx="12" cy="124" r="5" class="dot-main"/>
              <circle cx="12" cy="176" r="4" class="dot-main dim"/>
            </svg>
          </div>
      </div>
    </div>

    <section class="recent-posts">
        <div class="section-header">
          <h2>{translate(locale, 'home.recentPosts')}</h2>
          <div class="section-line"></div>
        </div>
        <div class="posts-grid">
            {recentPosts.map((post) => (
                <ArticleCard
                    url={`/${locale}/posts/${post.slug.replace(`${locale}/`, '')}/`}
                    title={post.data.title}
                    description={post.data.description}
                    pubDate={post.data.pubDate}
                    tags={post.data.tags}
                    image={post.data.image}
                    locale={locale}
                />
            ))}
        </div>
      <a href={`/${locale}/posts/`} class="view-all-link">
        {translate(locale, 'home.viewAllPosts')}
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </section>

</BaseLayout>

<style>
  .hero-section {
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
  }

  .hero-container {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 4rem 2rem 3.5rem;
    position: relative;
  }

  .hero-content {
    max-width: 720px;
  }

  .hero-intro {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .hero-avatar {
    width: 72px;
    height: 72px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .hero-meta {
    display: flex;
    flex-direction: column;
  }

  .hero-greeting {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-color);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .hero-title {
    font-family: 'Hacked', var(--font-display, 'Source Sans 3', sans-serif);
    font-size: 2.5rem;
    font-weight: normal;
    color: var(--text-primary);
    line-height: 1.15;
    margin: 0;
  }

  .hero-role {
    font-size: 1rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  .hero-bio {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .hero-bio p {
    font-size: 1.05rem;
    color: var(--text-tertiary);
    line-height: 1.7;
    margin: 0;
  }

  .hero-decoration {
    position: absolute;
    right: 2rem;
    top: 50%;
    transform: translateY(-50%);
  }

  .git-graph .line-main {
    stroke: var(--accent-color);
    opacity: 0.35;
  }

  .git-graph .dot-main {
    fill: var(--accent-color);
    opacity: 0.7;
  }

  .git-graph .dim {
    opacity: 0.2;
  }

  @media (max-width: 768px) {
    .hero-container {
      padding: 3rem 1.5rem 2.5rem;
    }

    .hero-intro {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .hero-avatar {
      width: 56px;
      height: 56px;
    }

    .hero-title {
      font-size: 2rem;
    }

    .hero-decoration {
      display: none;
    }
  }

  /* Recent Posts */
  .recent-posts {
    max-width: var(--container-max, 1200px);
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .section-header h2 {
    font-family: var(--font-display, 'Source Sans 3', sans-serif);
    font-size: 1.75rem;
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    margin: 0;
  }

  .section-line {
    flex: 1;
    height: 1px;
    background: var(--border-color);
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .view-all-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--accent-color);
    text-decoration: none;
    padding: 0.5rem 0;
    transition: gap 0.2s ease;
  }

  .view-all-link:hover {
    gap: 0.75rem;
  }

  @media (max-width: 768px) {
    .recent-posts {
      padding: 3rem 1.5rem;
    }

    .section-header h2 {
      font-size: 1.5rem;
    }

    .posts-grid {
      gap: 1rem;
    }
  }
</style>
